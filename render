# render.yaml – Deploy do backend no Render.com
# Faça push para o repositório e conecte no painel do Render

services:
  - type: web
    name: geocad-api
    runtime: docker
    dockerfilePath: ./docker/Dockerfile.backend
    dockerContext: ./backend
    plan: starter          # free tier – substitua por "standard" em produção
    region: ohio           # us-east-1 region (mais próximo do Brasil)
    envVars:
      - key: DATABASE_URL
        fromDatabase:
          name: geocad-db
          property: connectionString
      - key: SECRET_KEY
        generateValue: true
      - key: CORS_ORIGINS
        value: https://geocad.pages.dev
      - key: TEMP_DIR
        value: /tmp/geocad
      - key: DEBUG
        value: "false"
    disk:
      name: geocad-uploads
      mountPath: /tmp/geocad
      sizeGB: 10

databases:
  - name: geocad-db
    databaseName: geocad
    user: geocad
    plan: starter
    postgresMajorVersion: "16"
