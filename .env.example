# ── GeoCAD – Variáveis de Ambiente ───────────────────────────────────────────
# Copie este arquivo para .env e ajuste os valores antes de rodar.

# ── Banco de Dados ────────────────────────────────────────────────────────────
POSTGRES_DB=geocad
POSTGRES_USER=geocad
POSTGRES_PASSWORD=geocad_secret_mude_em_producao

# URL completa usada pelo backend (gerada automaticamente pelo docker-compose)
DATABASE_URL=postgresql://geocad:geocad_secret_mude_em_producao@db:5432/geocad

# ── Segurança ─────────────────────────────────────────────────────────────────
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-esta-chave-em-producao

# ── CORS – origens permitidas (separadas por vírgula) ─────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
TEMP_DIR=/tmp/geocad

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL do backend vista pelo navegador (em produção, use seu domínio real)
VITE_API_URL=http://localhost:8000

# ── APIs Externas ─────────────────────────────────────────────────────────────
OVERPASS_URL=https://overpass-api.de/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ── Debug (desative em produção) ──────────────────────────────────────────────
DEBUG=false
